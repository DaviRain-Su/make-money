# =============================================================================
# agent_trader environment configuration
# Copy this file to .env and fill in the blanks. Never commit the real .env.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Free-form environment name (dev / staging / prod). Only used for logs/UI.
APP_ENV=dev

# -----------------------------------------------------------------------------
# Execution path selector
# -----------------------------------------------------------------------------
# true  = use direct OKX native API (recommended, default)
# false = route through Hummingbot connector (requires a running Hummingbot API)
USE_OKX_NATIVE=true

# Hummingbot connector id. Only relevant when USE_OKX_NATIVE=false.
OKX_CONNECTOR_ID=okx_perpetual

# Single market the system is allowed to trade. OKX perpetual instrument id.
OKX_SYMBOL=BTC-USDT-SWAP

# -----------------------------------------------------------------------------
# OKX API credentials
# -----------------------------------------------------------------------------
# Create demo keys first: https://www.okx.com/account/my-api (use the
# "simulated trading" tab for OKX_FLAG=1). Never use a real-trading key while
# testing. The `passphrase` is the one you set when creating the API key.
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# 1 = OKX demo / simulated trading (fake money, recommended for all testing)
# 0 = OKX live (real money). Only flip this after you have trust in the logs.
OKX_FLAG=1

# Margin mode sent with every order. cross | isolated
OKX_TD_MODE=cross

# Private websocket URL. Default is OKX production; demo account also uses this
# endpoint but presents a different auth context when OKX_FLAG=1.
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/private

# How often the background reconcile loop polls open-order status, in seconds.
RECONCILE_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# Hummingbot API (ignored when USE_OKX_NATIVE=true)
# -----------------------------------------------------------------------------
HBOT_ACCOUNT_NAME=primary
HBOT_API_URL=http://localhost:8000
HBOT_API_USERNAME=admin
HBOT_API_PASSWORD=admin

# -----------------------------------------------------------------------------
# Execution safety flags
# -----------------------------------------------------------------------------
# Master switch. When false, no order is ever sent to OKX; responses come back
# with status=disabled. Keep false until you have watched the paper loop for a
# while.
EXECUTION_ENABLED=false

# When true, every approved trade returns status=paper instead of being placed.
# Combined with EXECUTION_ENABLED=true this is the intended "dress rehearsal"
# mode. Set to false only after paper runs look correct.
PAPER_MODE=true

# Fraction of account equity used to size a new proposal before stop-distance
# adjustment. 0.1 = risk budget is 10% of equity per trade (capped by
# RISK_MAX_NOTIONAL_USD and remaining exposure).
PROPOSAL_RISK_FRACTION=0.1

# -----------------------------------------------------------------------------
# Audit + state file paths (all under var/ which is gitignored)
# -----------------------------------------------------------------------------
# Append-only JSONL of every pipeline decision. Watched by /ui/ and tooling.
AUDIT_LOG_PATH=var/logs/audit/events.jsonl

# Records client_signal_id values already processed, so a replayed /signal
# request cannot produce two positions.
SIGNAL_IDEMPOTENCY_PATH=var/state/signal_ids.txt

# Persistent halt flag. When present and halted=true, the risk engine rejects
# every trade with reason "trading halted".
CONTROL_STATE_PATH=var/state/control.json

# Single-use nonces consumed by /admin/* HMAC requests (replay protection).
ADMIN_NONCE_PATH=var/state/admin_nonces.txt

# -----------------------------------------------------------------------------
# /signal endpoint auth (strategy → agent_trader)
# -----------------------------------------------------------------------------
# Shared secret the strategy/bot sends via X-Signal-Secret header. Leave blank
# to disable auth ONLY when the port is firewalled to localhost.
SIGNAL_SHARED_SECRET=

# -----------------------------------------------------------------------------
# /admin endpoint auth (Hermes → agent_trader)
# -----------------------------------------------------------------------------
# Required for Hermes integration. Clients compute:
#   sig = hmac_sha256(secret, "{ts}.{nonce}.{path}.{canonical_json_body}")
# and send X-Admin-Timestamp, X-Admin-Nonce, X-Admin-Signature headers.
# Also doubles as the PIN for large manual_trade confirmations.
ADMIN_SHARED_SECRET=

# Notional threshold (USD) at/above which a manual_trade needs explicit
# `confirmation: "confirmed"` in the body.
ADMIN_SMALL_TRADE_USD=500

# Notional threshold (USD) at/above which manual_trade additionally needs
# `pin` equal to ADMIN_SHARED_SECRET.
ADMIN_LARGE_TRADE_USD=5000

# -----------------------------------------------------------------------------
# Hard risk limits — the approve/deny gate. Every path (signal + admin) checks
# these. Tighten to reduce blast radius; loosen only with a code review.
# -----------------------------------------------------------------------------
# Global kill switch via env. Also flippable at runtime via /admin/halt or the
# local UI; runtime halt is persisted in CONTROL_STATE_PATH.
TRADING_HALTED=false

# Max cumulative notional (USD) across all open positions + the new proposal.
RISK_MAX_NOTIONAL_USD=1000

# Max leverage allowed on any single trade.
RISK_MAX_LEVERAGE=3

# Daily realized PnL drawdown (percent of equity) that triggers a hard stop.
# Example: 2.0 means if daily_pnl_pct <= -2%, every new trade is blocked.
RISK_DAILY_LOSS_LIMIT_PCT=2

# Max acceptable expected slippage, in basis points. Proposals above this are
# rejected before hitting the exchange.
RISK_MAX_SLIPPAGE_BPS=15

# Floor under which the account is considered "too small to trade safely".
# Prevents new orders from being opened when equity is nearly wiped out.
RISK_MIN_EQUITY_USD=50
