# =============================================================================
# agent_trader 环境变量配置
# 把本文件复制为 .env 后再填具体值。真实的 .env 文件永远不要提交到仓库。
# =============================================================================

# -----------------------------------------------------------------------------
# 基础
# -----------------------------------------------------------------------------
# 自定义的环境名（dev / staging / prod），仅用于日志和 UI 展示。
APP_ENV=dev

# -----------------------------------------------------------------------------
# 执行路径选择
# -----------------------------------------------------------------------------
# true  = 走 OKX 原生 API（推荐，默认）
# false = 走 Hummingbot 连接器（需要另外部署一个 Hummingbot API 服务）
USE_OKX_NATIVE=true

# Hummingbot 的连接器 ID。仅在 USE_OKX_NATIVE=false 时使用。
OKX_CONNECTOR_ID=okx_perpetual

# 默认合约（payload 没带 symbol 时使用）。OKX 永续合约的 instrument id。
OKX_SYMBOL=BTC-USDT-SWAP

# 合约白名单，逗号分隔。留空 = 不限制（允许任意 OKX SWAP 合约）。
# 建议至少列出你真正想交易的那几个，防止 Hermes 的自然语言解析出错时把单
# 打到你没研究过的合约上。风控引擎会按该白名单拒绝其他合约。
# 示例：OKX_ALLOWED_SYMBOLS=BTC-USDT-SWAP,ETH-USDT-SWAP,SOL-USDT-SWAP
OKX_ALLOWED_SYMBOLS=

# -----------------------------------------------------------------------------
# OKX API 凭据
# -----------------------------------------------------------------------------
# 先申请 demo（模拟盘）密钥：https://www.okx.com/account/my-api
# 在页面里切到"模拟交易"标签，配合下面的 OKX_FLAG=1 使用。
# 调试阶段永远不要用真盘密钥。passphrase 是你创建密钥时设置的那个。
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# 1 = OKX demo / 模拟交易（假钱，所有测试都应该用这个）
# 0 = OKX 真实交易（真金白银）。只有在对日志完全信任后才切到 0。
OKX_FLAG=1

# 每次下单都会附带的保证金模式。cross = 全仓 / isolated = 逐仓
OKX_TD_MODE=cross

# 私有 websocket 地址。默认填的是生产地址；demo 账户也走同一个地址，
# OKX_FLAG=1 时会在登录时自动切到模拟盘上下文。
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/private

# 后台 reconcile 循环轮询未完成订单状态的间隔（秒）。
RECONCILE_POLL_INTERVAL_SECONDS=30

# -----------------------------------------------------------------------------
# Hummingbot API（USE_OKX_NATIVE=true 时忽略这一段）
# -----------------------------------------------------------------------------
HBOT_ACCOUNT_NAME=primary
HBOT_API_URL=http://localhost:8000
HBOT_API_USERNAME=admin
HBOT_API_PASSWORD=admin

# -----------------------------------------------------------------------------
# 执行安全开关
# -----------------------------------------------------------------------------
# 总开关。false 时绝不会向 OKX 发送订单，接口返回 status=disabled。
# 在你对 paper 模式的日志完全信任之前都保持 false。
EXECUTION_ENABLED=false

# true 时所有通过风控的单子返回 status=paper，不真下。
# 和 EXECUTION_ENABLED=true 搭配是预期的"彩排"模式。
# 在 paper 跑顺之前不要关。
PAPER_MODE=true

# 下单前按账户权益的比例算风险预算（止损距离调整之前的基准）。
# 0.1 表示单笔风险预算 = 权益的 10%
# （再被 RISK_MAX_NOTIONAL_USD 和剩余敞口二次限制）。
PROPOSAL_RISK_FRACTION=0.1

# -----------------------------------------------------------------------------
# 审计 + 状态文件路径（全部写在 var/ 下，已在 .gitignore 里）
# -----------------------------------------------------------------------------
# 仅追加的 JSONL 审计日志，记录每一步管线决策。/ui/ 和外部工具都读它。
AUDIT_LOG_PATH=var/logs/audit/events.jsonl

# 记录已经处理过的 client_signal_id，防止同一条信号被重放而开出两个仓位。
SIGNAL_IDEMPOTENCY_PATH=var/state/signal_ids.txt

# 持久化的暂停开关。文件里 halted=true 时，风控引擎直接以
# "trading halted" 拒绝所有下单请求。
CONTROL_STATE_PATH=var/state/control.json

# /admin/* 的 HMAC 请求使用过的 nonce（防重放）。
ADMIN_NONCE_PATH=var/state/admin_nonces.txt

# -----------------------------------------------------------------------------
# /signal 端点鉴权（策略 → agent_trader）
# -----------------------------------------------------------------------------
# 策略 / 机器人调用 /signal 时通过 X-Signal-Secret 头带上的共享密钥。
# 只有在端口已经严格限定在 localhost 的情况下才允许留空。
SIGNAL_SHARED_SECRET=

# -----------------------------------------------------------------------------
# /admin 端点鉴权（Hermes → agent_trader）
# -----------------------------------------------------------------------------
# Hermes 集成必填。客户端要计算：
#   sig = hmac_sha256(secret, "{ts}.{nonce}.{path}.{canonical_json_body}")
# 再把 X-Admin-Timestamp / X-Admin-Nonce / X-Admin-Signature 三个头带上。
# 这个值同时也是大额 manual_trade 确认用的 PIN。
ADMIN_SHARED_SECRET=

# manual_trade 达到该名义金额（USD）需要 body 里 `confirmation: "confirmed"`。
ADMIN_SMALL_TRADE_USD=500

# manual_trade 达到该名义金额（USD）还需要 body 里 `pin` 等于 ADMIN_SHARED_SECRET。
ADMIN_LARGE_TRADE_USD=5000

# -----------------------------------------------------------------------------
# 硬风控阈值 —— 通过 / 拒绝闸门。所有下单路径（信号 + admin）都要过。
# 想降低爆炸半径就收紧；放宽之前必须走 code review。
# -----------------------------------------------------------------------------
# 环境变量形式的总 kill switch。运行时也可以通过 /admin/halt 或本地 UI 翻转，
# 运行时的状态会持久化到 CONTROL_STATE_PATH。
TRADING_HALTED=false

# 所有未平仓 notional + 新 proposal 的上限（USD）。
RISK_MAX_NOTIONAL_USD=1000

# 单笔交易允许的最大杠杆。
RISK_MAX_LEVERAGE=3

# 触发硬停的当日回撤（占账户权益的百分比）。
# 示例：2.0 表示 daily_pnl_pct <= -2% 时，新单一律被拒。
RISK_DAILY_LOSS_LIMIT_PCT=2

# 允许的最大预期滑点（基点）。超过此值的 proposal 直接被拒，不进交易所。
RISK_MAX_SLIPPAGE_BPS=15

# 账户权益低于该值视为"太小不值得冒险"，禁止开新仓，避免在接近爆仓时继续开单。
RISK_MIN_EQUITY_USD=50

# -----------------------------------------------------------------------------
# 策略信号源（EMA/ATR 双均线 + ATR 止损）
# 默认关闭。开启后每次轮询会为每个目标合约拉 K 线，发现 EMA 交叉时
# 通过 /signal 管线发一条信号（仍需过风控）。
# -----------------------------------------------------------------------------
STRATEGY_ENABLED=false

# 空 = 用 OKX_ALLOWED_SYMBOLS；再空 = [OKX_SYMBOL]
STRATEGY_SYMBOLS=

# K 线级别（对应 OKX 的 bar 参数）：1m / 3m / 5m / 15m / 30m / 1H / 2H / 4H / 1D 等
STRATEGY_BAR=1H

# 每次拉多少根 K 线（需要 ≥ slow_ema + atr_period 才能算出指标）
STRATEGY_CANDLE_LIMIT=200

# 轮询间隔（秒）。1H K 线建议 300~600；短周期可改小。
STRATEGY_POLL_SECONDS=300

# 双 EMA 周期
STRATEGY_FAST_EMA=20
STRATEGY_SLOW_EMA=50

# ATR 周期 + 止损/止盈倍数
STRATEGY_ATR_PERIOD=14
STRATEGY_ATR_STOP_MULT=2.0
STRATEGY_ATR_TP_MULT=3.0

# 策略发出信号时默认带的杠杆、置信度、期望滑点
STRATEGY_LEVERAGE=2.0
STRATEGY_CONFIDENCE=0.6
STRATEGY_EXPECTED_SLIPPAGE_BPS=8

# 多时间周期共振过滤（震荡行情假突破过滤）
# STRATEGY_HIGHER_TF_BAR 例如 "4H"；留空 = 关闭过滤
# STRATEGY_HIGHER_TF_SLOW_EMA 例如 50；=0 关闭
# 需要两个字段同时非空才启用：主周期交叉方向必须和高周期 slow EMA
# 斜率同向才发信号。失败是 fail-closed（当拿不到高周期数据时不发）。
STRATEGY_HIGHER_TF_BAR=
STRATEGY_HIGHER_TF_SLOW_EMA=0

# 信号生成器名字（插件）。空 = 走内置 ema_atr 的 inline 路径。
# 注册自定义生成器：from agent_trader.signal_registry import register
#                   register("my_strategy", my_fn)
# 然后 STRATEGY_GENERATOR=my_strategy 切过去。
STRATEGY_GENERATOR=

# -----------------------------------------------------------------------------
# freqtrade 反向 adapter
# 当我们的风控拦下一条 /signal/freqtrade 信号时，调 freqtrade 的
# /api/v1/forceexit 让它删掉自以为开了的虚拟仓位。默认关闭。
# -----------------------------------------------------------------------------
FREQTRADE_API_URL=
FREQTRADE_API_USERNAME=
FREQTRADE_API_PASSWORD=
FREQTRADE_RECONCILE_ON_BLOCK=false

# -----------------------------------------------------------------------------
# 告警 webhook
# 发生 danger 级事件时 POST 结构化 JSON 到这个 URL：
# - 风控拒单 / execution 被拦
# - /ui/halt 或 /admin/halt 触发
# 留空 = 关闭告警。超时后 fire-and-forget，审计日志仍然记录。
# -----------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_TIMEOUT_SECONDS=5

# -----------------------------------------------------------------------------
# 保证金相关风控（面向多合约 / cross margin 场景）
# 仅当账户同步层能拿到对应字段时才会生效（OKX 原生已接入；Hummingbot 路径留空）。
# -----------------------------------------------------------------------------
# 账户级保证金率（OKX mgnRatio）低于该值时拒绝开新仓。
# 数值越大越健康，接近 1.0 就在强平边缘。
# 0 = 关闭此检查。建议多合约开满后至少设成 2.0。
RISK_MIN_MARGIN_RATIO=0

# (已用初始保证金 + 新仓所需初始保证金) / 总权益 超过该值时拒单。
# 1.0 = 关闭此检查。建议 cross margin 多合约场景调到 0.5 左右，给行情留缓冲。
RISK_MAX_MARGIN_UTILIZATION=1.0

# 可用保证金（OKX availEq）低于该值时拒单，防止在保证金枯竭时还在开新仓。
# 0 = 关闭此检查。
RISK_MIN_AVAIL_EQUITY_USD=0

# 单个合约的名义金额上限（USD）。该合约已有敞口 + 新仓 notional 超过上限即拒。
# 用来防止"把所有子弹都押到一个合约上"。0 = 关闭此检查。
# 多合约组合建议设成 RISK_MAX_NOTIONAL_USD 的 1/3 ~ 1/2。
RISK_MAX_NOTIONAL_PER_SYMBOL_USD=0

# 任意持仓距离强平价 (|markPx - liqPx| / markPx) 小于该比例时，禁止开新仓。
# 0 = 关闭此检查。例：0.1 表示任何仓离强平 < 10% 就停止新仓；平仓不受此限。
# 多合约 cross margin 强烈建议开到 0.1（10%）或更严。
RISK_MIN_LIQUIDATION_DISTANCE_PCT=0

# 同时允许持有多少个不同合约。超过时对"新合约开仓"拒单（加仓和平仓不受限）。
# 0 = 关闭此检查。多合约场景建议设 5 ~ 10 防止过度分散管理成本。
RISK_MAX_OPEN_POSITIONS=0
